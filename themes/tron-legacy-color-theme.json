  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#2a5060",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Documentation",
      "scope": ["comment.block.documentation", "comment.line.documentation"],
      "settings": {
        "foreground": "#3d6070",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": ["string", "string.quoted", "string.template"],
      "settings": {
        "foreground": "#ff9933"
      }
    },
    {
      "name": "String Escape",
      "scope": ["constant.character.escape", "string.regexp"],
      "settings": {
        "foreground": "#ffbb55"
      }
